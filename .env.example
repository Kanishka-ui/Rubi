# ==========================================
# SQheLp Backend Environment Variables
# ==========================================

# 1. JWT Authentication Secret (Generate a strong random string)
# You can generate one using: openssl rand -hex 32
SECRET_KEY="your-very-secret-key-please-change-in-production"

# 2. Production Database Credentials (AWS RDS, DigitalOcean, etc.)
# This user MUST have CREATE DATABASE privileges to allow CSV uploads.
MYSQL_HOST="localhost"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD="your-secure-password"
MYSQL_DATABASE="sqhelp_db"

# 3. LLM Configuration
LLM_PROVIDER="gemini"
GEMINI_API_KEY="your-google-gemini-api-key"

# 4. Frontend URL for CORS (Set to your Vercel URL in production)
FRONTEND_URL="http://localhost:3000"

# 5. Application Server
BACKEND_PORT="8000"
